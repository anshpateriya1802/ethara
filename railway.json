{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node backend/index.js",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "readiness": {
        "path": "/api/health"
      }
    }
  }
}
